# Centralized environment template for all BrandForge services

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=contentengine
POSTGRES_PASSWORD=changeme_secure_password
POSTGRES_DB=contentengine

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# OpenAI (shared by backend + ai-image-agent)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Backend
BACKEND_PORT=3000
NODE_ENV=development
# For local non-docker runs. In Docker Compose this is overridden to http://ai-image-agent:4100
AI_IMAGE_AGENT_URL=http://localhost:4100
# Optional override for Chromium path used by backend renderer
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Frontend
VITE_API_URL=http://localhost:3000/api
# Optional Vite dev-server proxy target (used by frontend/vite.config.ts)
VITE_API_TARGET=http://backend:3000

# AI Image Agent
PORT=4100
RENDER_OUTPUT_DIR=output
AGENT_STATE_FILE=output/jobs-state.json
DELIVERY_BASE_URL=http://localhost:4100
DEFAULT_VARIANT_COUNT=3
MAX_VARIANT_COUNT=5
